# Node.js dependency install output.
# These packages are reconstructed from lockfiles and should not be versioned.
node_modules/

# Frontend build output generated by Vite/TypeScript.
# This directory is fully reproducible from source code.
dist/

# Test coverage and local tool caches.
# They are machine-local artifacts and add noise to diffs.
coverage/
.vite/

# Browser automation and local review outputs.
# These folders contain transient logs, snapshots, and verification artifacts.
.playwright-cli/
output/

# Local workflow scratch data produced by Codex/Superpowers runs.
# Keep these out of Git unless you explicitly decide to version them later.
.runs/
.superpowers/

# Local editor/runtime environment state.
# This is specific to the current machine and workspace session.
.codex/

# Common log files created during local debugging or test runs.
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# macOS Finder metadata files.
# They are unrelated to the project and should always stay untracked.
.DS_Store
